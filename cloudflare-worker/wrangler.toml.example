name = "phillipsburg-radio-feed-config"
main = "src/index.js"
compatibility_date = "2026-05-11"

[[kv_namespaces]]
binding = "FEED_CONFIG"
id = "replace-with-your-kv-namespace-id"

[vars]
FEED_CONFIG_KEY = "current-feed"
BROADCASTIFY_API_BASE_URL = "https://api.broadcastify.com/audio/"
BROADCASTIFY_FEED_ID = "45951"
CACHE_SECONDS = "60"
STREAM_URL_TTL_SECONDS = "300"
FORCE_REFRESH_MIN_SECONDS = "15"

# Set secrets, not in this file:
# wrangler secret put BROADCASTIFY_API_KEY
# wrangler secret put UPDATE_TOKEN
