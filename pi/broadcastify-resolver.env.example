# Copy this file to pi/broadcastify-resolver.env for local testing, or to
# /etc/phillipsburg-radio/resolver.env for the systemd service.

# Your Broadcastify feed/player page. Use the page source that contains exactly
# one .mp3 URL.
BROADCASTIFY_FEED_PAGE_URL=https://www.broadcastify.com/listen/feed/YOUR_FEED_ID

# Cloudflare Worker update endpoint. The iPhone app reads /current-feed.json,
# but the Pi writes to /update.
CONFIG_UPLOAD_URL=https://YOUR-WORKER.YOUR-SUBDOMAIN.workers.dev/update

# Long random secret shared only by the Pi and the Cloudflare Worker.
# Generate one with: openssl rand -hex 32
CONFIG_UPLOAD_TOKEN=replace-with-a-long-random-token

FEED_ID=phillipsburg_easton_public_safety
SOURCE=broadcastify-page-resolver
EXPIRES_SECONDS=300
OUTPUT_JSON_PATH=current-feed.json

# Set this only if Broadcastify requires your browser login/session to expose
# the player source. Keep it private and do not commit it.
# BROADCASTIFY_COOKIE=key=value; other=value

# Optional: true checks that the extracted stream URL responds before upload.
# This briefly opens the stream once from the Pi.
VALIDATE_STREAM=false
