# Phillipsburg Radio backend config
# This file belongs on the Raspberry Pi boot partition as phillipsburg-radio.env.
# After flashing the image, Windows/macOS should show this file on the SD card.

# Required for the live Phillipsburg feed: approved Broadcastify domain key.
BROADCASTIFY_API_KEY=

# Optional RadioReference SOAP database credentials.
# GitHub Actions fills these from repository secrets when they exist.
RADIOREFERENCE_API_KEY=
RADIOREFERENCE_USERNAME=
RADIOREFERENCE_PASSWORD=
RADIOREFERENCE_ENDPOINT=https://api.radioreference.com/soap2/
RADIOREFERENCE_VERSION=latest
RADIOREFERENCE_STYLE=rpc

# Optional but required for automatic completed-call transcripts.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_INCIDENT_MODEL=gpt-5.5
ENABLE_OPENAI_INCIDENT_ANALYSIS=1

# Your current hometown feed.
BROADCASTIFY_FEED_ID=45951

# Local backend server for the iPhone app.
BACKEND_BIND_HOST=0.0.0.0
BACKEND_PORT=80
PUBLIC_BASE_URL=http://franksplex.com:5214

# Admin token for POST /transcripts, /incidents, and /admin/*.
# Leave empty only for a personal debug image. Set
# ALLOW_DEBUG_ADMIN_WITHOUT_TOKEN=0 before sharing a public build.
BACKEND_ADMIN_TOKEN=change-me-admin-token
ALLOW_DEBUG_ADMIN_WITHOUT_TOKEN=1

# Defaults are normally fine.
BROADCASTIFY_EMBED_PLAYER_URL=https://api.broadcastify.com/embed/player/
BROADCASTIFY_REFERER=http://Franksplex.com/
BROADCASTIFY_LISTENERS_URL_TEMPLATE=http://api.broadcastify.com/listeners/feed/{feed_id}
STREAM_URL_TTL_SECONDS=300
CACHE_SECONDS=60
OUTPUT_JSON_PATH=/var/lib/phillipsburg-radio/current-feed.json
TRANSCRIPTS_PATH=/var/lib/phillipsburg-radio/transcripts.jsonl
INCIDENTS_PATH=/var/lib/phillipsburg-radio/incidents.jsonl
INCIDENT_STATE_PATH=/var/lib/phillipsburg-radio/incident-state.json
PIPELINE_STATUS_PATH=/var/lib/phillipsburg-radio/transcript-pipeline-status.json
REQUEST_TIMEOUT_SECONDS=20

# Completed-call recording and cleanup.
RECORDINGS_DIR=/var/lib/phillipsburg-radio/recordings
TRANSCRIPT_CHUNK_SECONDS=25
TRANSCRIPT_SLEEP_SECONDS=4
MIN_SPEECH_SECONDS=3
MAX_INCIDENT_AGE_SECONDS=2700
AUDIO_CLEANUP_FILTER=highpass=f=250,lowpass=f=3600,afftdn=nf=-28,loudnorm=I=-18:TP=-2:LRA=11
TRANSCRIPTION_CONTEXT_PROMPT=Scanner audio from Phillipsburg New Jersey and Easton Pennsylvania public safety radio. Include dispatch, police, fire, EMS, streets, units, and incident updates. Do not invent unclear details.
